# ============================================
# ArchLens - Environment Variables
# ============================================
# Copy this file to .env and fill in values

# --- AI Providers ---
OPENAI_API_KEY=sk-your-openai-key
GOOGLE_AI_API_KEY=your-google-ai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- PostgreSQL (Upload + Orchestrator) ---
POSTGRES_USER=archlens
POSTGRES_PASSWORD=archlens_dev_2026
POSTGRES_DB=archlens

# --- MongoDB (Report Service) ---
MONGO_INITDB_ROOT_USERNAME=archlens
MONGO_INITDB_ROOT_PASSWORD=archlens_dev_2026

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=archlens
RABBITMQ_DEFAULT_PASS=archlens_dev_2026

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=archlens
MINIO_ROOT_PASSWORD=archlens_dev_2026

# --- Redis ---
REDIS_PASSWORD=archlens_dev_2026

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_ISSUER=archlens
JWT_AUDIENCE=archlens-client
JWT_EXPIRY_MINUTES=60

# --- Service URLs (for local dev) ---
UPLOAD_SERVICE_URL=http://localhost:5066
ORCHESTRATOR_SERVICE_URL=http://localhost:5089
REPORT_SERVICE_URL=http://localhost:5205
NOTIFICATION_SERVICE_URL=http://localhost:5150
AI_SERVICE_URL=http://localhost:8000
GATEWAY_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
