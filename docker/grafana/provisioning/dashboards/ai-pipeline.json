{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Analises por Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (archlens_analysis_total)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Tempo Medio de Processamento (ms)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "avg(archlens_analysis_duration_ms)",
          "legendFormat": "Media"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      }
    },
    {
      "title": "Taxa de Sucesso por Provider",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(archlens_provider_success_total) by (provider) / (sum(archlens_provider_success_total) by (provider) + sum(archlens_provider_failure_total) by (provider)) * 100",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Duração de Analise por Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(archlens_provider_duration_seconds_bucket[5m])) by (provider, le)) * 1000",
          "legendFormat": "{{provider}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "Consensus Confidence Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "archlens_consensus_confidence_bucket",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(archlens_cache_hits_total) / (sum(archlens_cache_hits_total) + sum(archlens_cache_misses_total)) * 100",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "title": "SAGA State Transitions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(archlens_saga_transitions_total[5m])) by (from_state, to_state)",
          "legendFormat": "{{from_state}} → {{to_state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["archlens", "ai", "pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "ArchLens - AI Pipeline",
  "uid": "archlens-ai-pipeline"
}
